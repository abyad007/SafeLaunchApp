{
  "$schema": "https://design-tokens.org/schema.json",
  "$meta": {
    "name": "Versigent Safe Launch — Design System",
    "version": "1.0.0",
    "product": "Analytics / BI Dashboard (data-dense, enterprise)",
    "brand": "Versigent",
    "fonts": "Barlow Condensed (display) + Barlow (body) — Google Fonts",
    "notes": "Three-layer tokens (primitive -> semantic -> component). Brand copper #CD7925 is reserved for borders/fills/badges; text on light uses the darker copper-700 to meet WCAG AA (>=4.5:1)."
  },

  "primitive": {
    "color": {
      "navy": {
        "900": { "$value": "#16283F", "$type": "color", "$desc": "Brand ink / primary dark" },
        "800": { "$value": "#1F3553", "$type": "color", "$desc": "Header gradient end" },
        "700": { "$value": "#2B4566", "$type": "color" },
        "600": { "$value": "#3C5A80", "$type": "color" }
      },
      "copper": {
        "500": { "$value": "#CD7925", "$type": "color", "$desc": "Brand accent — borders/fills/large only (3.30:1 on white)" },
        "600": { "$value": "#B36A1E", "$type": "color" },
        "700": { "$value": "#9A5A14", "$type": "color", "$desc": "Copper for TEXT on light — 5.4:1 AA" }
      },
      "gold": {
        "400": { "$value": "#F7A900", "$type": "color", "$desc": "Header tag accent — for use on dark only" }
      },
      "stone": {
        "50":  { "$value": "#FAFAF7", "$type": "color" },
        "100": { "$value": "#F4F1EA", "$type": "color", "$desc": "Warm secondary surface (sidebar/cards)" },
        "200": { "$value": "#E5DFD3", "$type": "color", "$desc": "Warm border" }
      },
      "gray": {
        "400": { "$value": "#9CA3AF", "$type": "color", "$desc": "Decorative only — fails AA as text" },
        "500": { "$value": "#6B7280", "$type": "color", "$desc": "4.7:1 — minimum for secondary text" },
        "600": { "$value": "#64748B", "$type": "color", "$desc": "Muted text — 4.8:1 AA" },
        "700": { "$value": "#374151", "$type": "color" },
        "900": { "$value": "#111827", "$type": "color" }
      },
      "red":   { "500": { "$value": "#DC2626", "$type": "color", "$desc": "Risk HIGH fill/badge" },
                 "700": { "$value": "#B91C1C", "$type": "color", "$desc": "Risk HIGH text — 5.9:1 AA" },
                 "bg":  { "$value": "#FFF0EE", "$type": "color" } },
      "amber": { "500": { "$value": "#D97706", "$type": "color", "$desc": "Risk MEDIUM fill/badge" },
                 "700": { "$value": "#B45309", "$type": "color", "$desc": "Risk MEDIUM text — 4.6:1 AA" },
                 "bg":  { "$value": "#FFF7ED", "$type": "color" } },
      "green": { "500": { "$value": "#16A34A", "$type": "color", "$desc": "Risk LOW / done fill" },
                 "700": { "$value": "#15803D", "$type": "color", "$desc": "Done text — 4.5:1 AA" },
                 "800": { "$value": "#166534", "$type": "color" },
                 "bg":  { "$value": "#F0FFF4", "$type": "color" } },
      "white": { "$value": "#FFFFFF", "$type": "color" }
    },

    "spacing": {
      "1": { "$value": "4px",  "$type": "dimension" },
      "2": { "$value": "8px",  "$type": "dimension" },
      "3": { "$value": "12px", "$type": "dimension" },
      "4": { "$value": "16px", "$type": "dimension" },
      "5": { "$value": "20px", "$type": "dimension" },
      "6": { "$value": "24px", "$type": "dimension" },
      "8": { "$value": "32px", "$type": "dimension" }
    },

    "fontFamily": {
      "display": { "$value": "'Barlow Condensed', sans-serif", "$type": "fontFamily" },
      "body":    { "$value": "'Barlow', sans-serif", "$type": "fontFamily" }
    },

    "fontSize": {
      "xs":   { "$value": "11px", "$type": "dimension", "$desc": "Captions/labels — uppercase only" },
      "sm":   { "$value": "12px", "$type": "dimension", "$desc": "Min body size" },
      "base": { "$value": "14px", "$type": "dimension", "$desc": "Default body" },
      "md":   { "$value": "16px", "$type": "dimension" },
      "lg":   { "$value": "18px", "$type": "dimension" },
      "xl":   { "$value": "22px", "$type": "dimension" },
      "2xl":  { "$value": "28px", "$type": "dimension", "$desc": "Metric value / H1" }
    },

    "fontWeight": {
      "regular": { "$value": "400", "$type": "number" },
      "medium":  { "$value": "500", "$type": "number" },
      "semibold":{ "$value": "600", "$type": "number" },
      "bold":    { "$value": "700", "$type": "number" }
    },

    "lineHeight": {
      "tight":  { "$value": "1.1", "$type": "number" },
      "normal": { "$value": "1.5", "$type": "number" }
    },

    "letterSpacing": {
      "label": { "$value": "2px",   "$type": "dimension" },
      "wide":  { "$value": "2.5px", "$type": "dimension" }
    },

    "radius": {
      "sm":   { "$value": "3px", "$type": "dimension" },
      "base": { "$value": "6px", "$type": "dimension" },
      "lg":   { "$value": "8px", "$type": "dimension" }
    },

    "shadow": {
      "card": { "$value": "0 1px 3px rgba(22,40,63,0.06)", "$type": "shadow" },
      "raised": { "$value": "0 2px 6px rgba(22,40,63,0.10)", "$type": "shadow" }
    }
  },

  "semantic": {
    "color": {
      "background":        { "$value": "{primitive.color.white}", "$type": "color" },
      "surface":           { "$value": "{primitive.color.white}", "$type": "color" },
      "surface-alt":       { "$value": "{primitive.color.stone.100}", "$type": "color" },
      "foreground":        { "$value": "{primitive.color.navy.900}", "$type": "color" },
      "muted-foreground":  { "$value": "{primitive.color.gray.600}", "$type": "color" },
      "border":            { "$value": "{primitive.color.stone.200}", "$type": "color" },

      "primary":           { "$value": "{primitive.color.navy.900}", "$type": "color" },
      "on-primary":        { "$value": "{primitive.color.white}", "$type": "color" },

      "accent":            { "$value": "{primitive.color.copper.500}", "$type": "color", "$desc": "Borders/fills/large UI" },
      "accent-text":       { "$value": "{primitive.color.copper.700}", "$type": "color", "$desc": "Copper as text on light (AA)" },
      "accent-on-dark":    { "$value": "{primitive.color.gold.400}", "$type": "color" },

      "risk-high":         { "$value": "{primitive.color.red.500}",   "$type": "color" },
      "risk-high-text":    { "$value": "{primitive.color.red.700}",   "$type": "color" },
      "risk-high-bg":      { "$value": "{primitive.color.red.bg}",    "$type": "color" },
      "risk-medium":       { "$value": "{primitive.color.amber.500}", "$type": "color" },
      "risk-medium-text":  { "$value": "{primitive.color.amber.700}", "$type": "color" },
      "risk-medium-bg":    { "$value": "{primitive.color.amber.bg}",  "$type": "color" },
      "risk-low":          { "$value": "{primitive.color.green.500}", "$type": "color" },
      "risk-low-text":     { "$value": "{primitive.color.green.700}", "$type": "color" },
      "risk-low-bg":       { "$value": "{primitive.color.green.bg}",  "$type": "color" }
    }
  },

  "theme": {
    "dark": {
      "$desc": "Versigent dark mode — keeps navy+copper DNA. Backgrounds deepen, copper accent lightens for text (>=5:1 on dark). Status colors use 400-tier text + dark tints.",
      "background":        { "$value": "#0E1B2E", "$type": "color", "$desc": "Deep navy canvas" },
      "surface":           { "$value": "#16283F", "$type": "color", "$desc": "Card — brand navy, lifted from canvas" },
      "surface-alt":       { "$value": "#1B3050", "$type": "color", "$desc": "Sidebar / inputs / todo" },
      "foreground":        { "$value": "#EAF0F7", "$type": "color", "$desc": "15:1 on canvas" },
      "muted-foreground":  { "$value": "#9FB0C3", "$type": "color", "$desc": "7.8:1 on canvas" },
      "border":            { "$value": "#2E4564", "$type": "color" },
      "accent":            { "$value": "#CD7925", "$type": "color", "$desc": "Copper — 5.2:1 on canvas (fills/borders/large)" },
      "accent-text":       { "$value": "#E89B4D", "$type": "color", "$desc": "Lighter copper for small text — 7.6:1" },
      "risk-high":         { "$value": "#DC2626", "$type": "color" },
      "risk-high-text":    { "$value": "#F87171", "$type": "color", "$desc": "6.2:1 on canvas" },
      "risk-high-bg":      { "$value": "#3A1B1E", "$type": "color" },
      "risk-medium":       { "$value": "#D97706", "$type": "color" },
      "risk-medium-text":  { "$value": "#FBBF24", "$type": "color" },
      "risk-medium-bg":    { "$value": "#3A2A12", "$type": "color" },
      "risk-low":          { "$value": "#16A34A", "$type": "color" },
      "risk-low-text":     { "$value": "#4ADE80", "$type": "color" },
      "risk-low-bg":       { "$value": "#13301F", "$type": "color" }
    }
  },

  "component": {
    "card": {
      "background":  { "$value": "{semantic.color.surface}", "$type": "color" },
      "border":      { "$value": "{semantic.color.border}", "$type": "color" },
      "border-top":  { "$value": "{semantic.color.accent}", "$type": "color" },
      "radius":      { "$value": "{primitive.radius.lg}", "$type": "dimension" },
      "padding":     { "$value": "{primitive.spacing.4}", "$type": "dimension" },
      "shadow":      { "$value": "{primitive.shadow.card}", "$type": "shadow" }
    },
    "metric": {
      "label-color": { "$value": "{primitive.color.gray.500}", "$type": "color" },
      "value-color": { "$value": "{semantic.color.foreground}", "$type": "color" },
      "value-font":  { "$value": "{primitive.fontFamily.display}", "$type": "fontFamily" },
      "value-size":  { "$value": "{primitive.fontSize.2xl}", "$type": "dimension" }
    },
    "header": {
      "background":  { "$value": "linear-gradient(135deg, #16283F 0%, #1F3553 100%)", "$type": "gradient" },
      "border-bottom": { "$value": "{semantic.color.accent}", "$type": "color" },
      "title-font":  { "$value": "{primitive.fontFamily.display}", "$type": "fontFamily" }
    }
  }
}
